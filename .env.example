# Sao chép thành .env.local rồi điền giá trị (file .env* có đuôi .local đã được gitignore).
# Cảnh báo: biến VITE_* được đóng gói vào JS — App Secret chỉ nên dùng khi dev local.
#
# Vercel: Project Settings → Environment Variables — thêm cùng các biến VITE_LARK_* (Production).
# KHÔNG set VITE_LARK_API_BASE=/lark-open-api trên Vercel (chỉ dùng khi npm run dev).
# App production gọi Lark qua /api/lark (api/lark/[...path].js). Sau khi sửa vercel.json cần Redeploy.

VITE_LARK_APP_ID=
# ⬇️ Điền App Secret của app Lark tại đây (hoặc bỏ trống và nhập trong modal Lark Base trên UI)
VITE_LARK_APP_SECRET=

VITE_LARK_BASE_APP_TOKEN=
VITE_LARK_TABLE_OFFICE=
VITE_LARK_TABLE_TRIPS=
VITE_LARK_TABLE_COMMUTE=
